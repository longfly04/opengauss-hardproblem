COMPOSE_PROJECT_NAME=oglab
OPENGAUSS_RUNTIME_MODE=stock
OPENGAUSS_IMAGE=opengauss/opengauss-server:latest
OPENGAUSS_SOURCE_IMAGE=local/opengauss-source-runtime:latest
OPENGAUSS_DEV_IMAGE=local/opengauss-source-dev:latest
DB_SERVICE_NAME=opengauss
DB_HOST=opengauss
DB_PORT=5432
DB_CONTAINER_USER=omm
DB_CLIENT_BIN=gsql
DB_NAME=benchdb
DB_ADMIN_USER=gaussdb
DB_ADMIN_PASSWORD=ChangeMe_123
GS_PASSWORD=ChangeMe_123
BENCH_USER=bench
BENCH_PASSWORD=bench_123
EXPORTER_USER=exporter
EXPORTER_PASSWORD=exporter_123
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OG_MEMORY_EXPORTER_PORT=9188
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8080
PROMETHEUS_RETENTION_TIME=15d
SYSBENCH_IMAGE=openeuler/sysbench:latest
TPCC_IMAGE=local/opengauss-tpcc-runner:latest
TPCH_IMAGE=local/opengauss-tpch-tools:latest
OPENGAUSS_SOURCE_DIR=./openGauss-server
OPENGAUSS_THIRD_PARTY_DIR=./openGauss-third_party
OPENGAUSS_BUILD_TYPE=debug
OPENGAUSS_INSTALL_PREFIX=/opt/opengauss/install
OPENGAUSS_DATA_DIR=/var/lib/opengauss
OPENGAUSS_LOG_DIR=/var/log/opengauss
OPENGAUSS_NODE_NAME=single_node
OPENGAUSS_DEBUG_PORT=2345
